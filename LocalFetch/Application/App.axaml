<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
             x:Class="LocalFetch.App"
             xmlns:local="using:LocalFetch"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
             
     <Application.Styles>
         <actipro:ModernTheme/>
     </Application.Styles>
    
    <Application.Resources>
        <RadialGradientBrush x:Key="RadialBackground"
                             Center="2.0, 0.0"
                             GradientOrigin="2.0, 1.0" SpreadMethod="Pad"
                             Radius="0.5">
            <GradientStop Color="#2B2D30" Offset="1.0" />
        </RadialGradientBrush>
    </Application.Resources>
</Application>