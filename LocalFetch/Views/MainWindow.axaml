<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocalFetch.ViewModels"
        Width="783" Height="641" CanResize="False"
        MinWidth="783" MinHeight="641"
        WindowStartupLocation="CenterScreen"
        x:Class="LocalFetch.Views.MainWindow"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        xmlns:primitives="clr-namespace:ActiproSoftware.UI.Avalonia.Controls.Primitives;assembly=ActiproSoftware.Avalonia.Shared"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/LocalFetch.ico"
        Background="#2B2D30"
        FontFamily="Segoe UI"
        Title="Local Fetch">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
	    <actipro:ChromedTitleBar DockPanel.Dock="Top"
	                             Background="{StaticResource RadialBackground}"
	    >
		    <actipro:ChromedTitleBar.Styles>
			    <!-- Hover Style for All Buttons in ChromedTitleBar -->
			    <Style Selector="Button:pointerover">
				    <Setter Property="Background" Value="LightGray" />
			    </Style>
		    </actipro:ChromedTitleBar.Styles>
		    
		    <actipro:ChromedTitleBar.Resources>
			    <actipro:ComparisonConverter x:Key="RightContentMarginConverter">
				    <actipro:ComparisonConverter.TrueResult>
					    <Thickness>0,0,20,0</Thickness>
				    </actipro:ComparisonConverter.TrueResult>
				    <actipro:ComparisonConverter.FalseResult>
					    <Thickness>0,0,0,0</Thickness>
				    </actipro:ComparisonConverter.FalseResult>
			    </actipro:ComparisonConverter>
		    </actipro:ChromedTitleBar.Resources>
		    
		    <actipro:ChromedTitleBar.LeftContent>
				<StackPanel Orientation="Horizontal">
					<StackPanel Margin="15,7,0,7" VerticalAlignment="Center">
						<Border Height="33" Width="" Background="Black"></Border>
					</StackPanel>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="Welcome to Local Fetch"
						           VerticalAlignment="Center"
						           IsHitTestVisible="False"
						           Foreground="#6A7176"
						           Margin="0,8,0,7"
						           TextTrimming="CharacterEllipsis"/>
					</StackPanel>
				</StackPanel>
			</actipro:ChromedTitleBar.LeftContent>
		    
		    <primitives:OverlayInputFilter>
			    <Grid>
				    <actipro:WindowResizeGrip/>
				    <Grid.RowDefinitions>
					    <RowDefinition Height="1"/>
				    </Grid.RowDefinitions>
			    </Grid>
		    </primitives:OverlayInputFilter>
		</actipro:ChromedTitleBar>
	    
	    <Border DockPanel.Dock="Bottom"
	            BorderBrush="Transparent" 
	            BorderThickness="{actipro:ThemeResource StatusBarBorderThickness}">
		    <Grid Margin="0,0,0,1">
			    <Grid.ColumnDefinitions>
				    <ColumnDefinition Width="224" />
				    <ColumnDefinition Width="*" />
			    </Grid.ColumnDefinitions>
        
			    <Border Grid.Column="0" Background="Transparent">
				    <TextBlock Text="Left Panel" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			    </Border>
			    
			    <Border Grid.Column="1" Background="#1E1F22">
				    <ScrollViewer Classes="theme-scroll-overlay">
					    <StackPanel Margin="13 0 0 0">
						    <Button Width="511" 
						            Height="52" 
						            Background="Transparent" 
						            BorderBrush="Transparent"
						            CornerRadius="5"
						            Foreground="White"
						            Content="Button Tile">
							    <Button.Styles>
								    <!-- Default Style -->
								    <Style Selector="Button">
									    <Setter Property="Background" Value="Transparent"/>
									    <Setter Property="Foreground" Value="White"/>
								    </Style>
        
								    <!-- Hover Style -->
								    <Style Selector="Button:pointerover">
									    <Setter Property="Background" Value="#2E436E"/>
									    <Setter Property="Foreground" Value="White"/>
								    </Style>
							    </Button.Styles>
						    </Button>
					    </StackPanel>
				    </ScrollViewer>
			    </Border>
		    </Grid>
	    </Border>
	</DockPanel>
</Window>
