<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LocalFetch.ViewModels"
        Width="786" Height="642"
        MinWidth="786" MinHeight="642"
        WindowStartupLocation="CenterScreen"
        x:Class="LocalFetch.Views.MainWindow"
        xmlns:actipro="http://schemas.actiprosoftware.com/avaloniaui"
        xmlns:primitives="clr-namespace:ActiproSoftware.UI.Avalonia.Controls.Primitives;assembly=ActiproSoftware.Avalonia.Shared"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/LocalFetch.ico"
        Background="#2B2D30"
        Title="Local Fetch">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
		<actipro:ChromedTitleBar DockPanel.Dock="Top"
		                         Background="#2B2D30"
		>
			<actipro:ChromedTitleBar.LeftContent>
				<primitives:OverlayInputFilter>
					<StackPanel Orientation="Horizontal" IsHitTestVisible="True">
						<StackPanel Margin="10,7,0,7" VerticalAlignment="Center" IsHitTestVisible="True">
							<Border Height="30"></Border>
						</StackPanel>
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Welcome to Local Fetch"
							           VerticalAlignment="Center"
							           IsHitTestVisible="False"
							           Foreground="#6A7176"
							           Margin="10,8,0,7"
							           TextTrimming="CharacterEllipsis"/>
						</StackPanel>
					</StackPanel>
				</primitives:OverlayInputFilter>
			</actipro:ChromedTitleBar.LeftContent>
		</actipro:ChromedTitleBar>
	    
	    <primitives:OverlayInputFilter>
		    <Grid>
			    <actipro:WindowResizeGrip/>
			    <Grid.RowDefinitions>
				    <RowDefinition Height="1"/>
				    <RowDefinition Height="*"/>
			    </Grid.RowDefinitions>
			    
			    <!--<Border Grid.Row="0" Height="1" Background="#1E1F22"></Border>-->
		    </Grid>
	    </primitives:OverlayInputFilter>
	</DockPanel>
</Window>
