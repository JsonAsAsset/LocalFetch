        Width="1160" Height="770" RequestedThemeVariant="Dark" FontFamily="Segoe UI" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/LocalFetch.ico"
        TransparencyLevelHint="Mica"
        Title="Local Fetch">

    <Panel>
    </Panel>
</Window>
